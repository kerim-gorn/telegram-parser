# PostgreSQL
POSTGRES_DB=parser_llm
POSTGRES_USER=parser_llm
POSTGRES_PASSWORD=parser_llm_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://parser_llm:parser_llm_password@postgres:5432/parser_llm

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:redis_password@redis:6379/0
SESSION_REDIS_PREFIX=telegram_session:

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=parser_llm
RABBITMQ_PASSWORD=rabbitmq_password
RABBITMQ_VHOST=/
AMQP_URL=amqp://parser_llm:rabbitmq_password@rabbitmq:5672//

# Celery
CELERY_BROKER_URL=${AMQP_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# Telegram API
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_APP_TITLE=Parser-LLM
SESSION_SECRET_KEY=change-me-super-secret-32-bytes

# App
TIMEZONE=UTC
