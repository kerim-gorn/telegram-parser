# ============================================
# TELEGRAM API CREDENTIALS
# ============================================
# Получить на https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890
# Если используется бот-токен (опционально)
TELEGRAM_BOT_TOKEN=

# ============================================
# POSTGRESQL DATABASE
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=parser_llm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password_here

# SQLAlchemy Database URL (автоматически формируется из переменных выше)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ============================================
# REDIS (Session Storage & Cache)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_here
REDIS_DB=0

# Redis URL для подключения
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ============================================
# RABBITMQ MESSAGE BROKER
# ============================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=rabbitmq
RABBITMQ_PASSWORD=rabbitmq_secure_password_here
RABBITMQ_VHOST=parser_llm

# RabbitMQ Broker URL для Celery
CELERY_BROKER_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/${RABBITMQ_VHOST}
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1

# ============================================
# CELERY CONFIGURATION
# ============================================
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# ============================================
# APPLICATION SETTINGS
# ============================================
# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Окружение (development, production)
ENVIRONMENT=development

# Шифрование сессий (для StringSession)
SESSION_ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# ============================================
# ANTI-BAN SETTINGS
# ============================================
# Настройки для избежания FloodWait
FLOOD_WAIT_MAX_DELAY=3600
FLOOD_WAIT_EXPONENTIAL_BASE=2
FLOOD_WAIT_JITTER_MAX=5

# Задержки между запросами (в секундах)
MIN_REQUEST_DELAY=1.0
MAX_REQUEST_DELAY=3.0

# Максимальное количество сообщений для парсинга за раз
MAX_MESSAGES_PER_BATCH=100

# ============================================
# CHAT IDS TO MONITOR
# ============================================
# Список ID чатов для мониторинга (через запятую)
# Можно указывать username (@channel) или числовые ID
MONITORED_CHATS=@channel1,@channel2,-1001234567890

# ============================================
# OPTIONAL: PROXY SETTINGS
# ============================================
# Если требуется прокси для Telegram
# PROXY_TYPE=socks5
# PROXY_HOST=proxy.example.com
# PROXY_PORT=1080
# PROXY_USERNAME=
# PROXY_PASSWORD=
